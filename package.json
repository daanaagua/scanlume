{
  "name": "scanlume",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "concurrently \"pnpm --dir apps/api dev\" \"pnpm --dir apps/web dev\"",
    "dev:web": "pnpm --dir apps/web dev",
    "dev:api": "pnpm --dir apps/api dev",
    "build": "pnpm --dir apps/web build && pnpm --dir apps/api typecheck",
    "lint": "pnpm --dir apps/web lint && pnpm --dir apps/api typecheck",
    "test": "pnpm test:web && pnpm test:api",
    "test:web": "pnpm --dir apps/web test",
    "test:api": "pnpm --dir apps/api test",
    "submit:indexnow": "node scripts/submit-indexnow.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
